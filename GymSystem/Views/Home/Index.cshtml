@model AnalyticsModelView
@{
    ViewData["Title"] = "Home";
}

<div class="home-wrap">

    <!-- ══ HERO ══════════════════════════════════════════════════ -->
    <section class="hero">
        <div class="hero-grid-lines"></div>
        <div class="hero-divider"></div>

        <div class="hero-left">
            <div class="h-eyebrow">
                <div class="h-eyebrow-line"></div>
                <span class="h-eyebrow-text">Elite Training &middot; Est. 2015</span>
            </div>

            <h1 class="hero-heading">
                YOUR BODY<br>
                CAN STAND<br>
                <span class="accent">ALMOST</span><br>
                ANYTHING
            </h1>

            <p class="hero-subtext">
                It's your mind that needs convincing. Push past your limits,
                stay committed, and watch your body transform into a powerhouse
                of strength and resilience. Start your journey today.
            </p>

            <div class="hero-btns">
                <button class="btn-primary-pf">Get Started</button>
                <button class="btn-outline-pf">Explore More</button>
            </div>
        </div>

        <div class="hero-right">
            <div class="hero-photo">
                <img src="~/images/download.png" alt="Theo Vance"
                     onerror="this.style.display='none'" />
                <div class="hero-photo-bg">PWR</div>
            </div>
        </div>
    </section>

    <!-- ══ STATS BAR ══════════════════════════════════════════════ -->
    <div class="stats-bar">
        <div class="stat-card">
            <div class="stat-icon">&#128101;</div>
            <div class="stat-value">@Model.TotalMembers</div>
            <div class="stat-label">Total Members</div>
            <div class="stat-bar"></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">&#9889;</div>
            <div class="stat-value">@Model.ActiveMembers</div>
            <div class="stat-label">Active Members</div>
            <div class="stat-bar"></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">&#127947;</div>
            <div class="stat-value">@Model.Trainers</div>
            <div class="stat-label">Trainers</div>
            <div class="stat-bar"></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">&#128197;</div>
            <div class="stat-value">@Model.UpcomingSessions</div>
            <div class="stat-label">Upcoming Sessions</div>
            <div class="stat-bar"></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">&#9654;</div>
            <div class="stat-value">@Model.OngoingSessions</div>
            <div class="stat-label">Ongoing Sessions</div>
            <div class="stat-bar"></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">&#10003;</div>
            <div class="stat-value">@Model.CompletedSessions</div>
            <div class="stat-label">Completed Sessions</div>
            <div class="stat-bar"></div>
        </div>
    </div>

    <!-- ══ TICKER ══════════════════════════════════════════════════ -->
    <div class="ticker">
        <div class="ticker-track">
            <span class="ticker-item">Outdoor &amp; Online Trainers <span class="ticker-dot"></span></span>
            <span class="ticker-item">Personal Training <span class="ticker-dot"></span></span>
            <span class="ticker-item">Live Classes <span class="ticker-dot"></span></span>
            <span class="ticker-item">Personal Trainers <span class="ticker-dot"></span></span>
            <span class="ticker-item">Group Workouts <span class="ticker-dot"></span></span>
            <span class="ticker-item">Nutrition Plans <span class="ticker-dot"></span></span>
            <span class="ticker-item">Outdoor &amp; Online Trainers <span class="ticker-dot"></span></span>
            <span class="ticker-item">Personal Training <span class="ticker-dot"></span></span>
            <span class="ticker-item">Live Classes <span class="ticker-dot"></span></span>
            <span class="ticker-item">Personal Trainers <span class="ticker-dot"></span></span>
            <span class="ticker-item">Group Workouts <span class="ticker-dot"></span></span>
            <span class="ticker-item">Nutrition Plans <span class="ticker-dot"></span></span>
        </div>
    </div>

    <!-- ══ ABOUT ══════════════════════════════════════════════════ -->
    <section class="about-sec">
        <div class="about-images">
            <div class="about-img about-img-main">
                <img src="~/images/Redhulk 2nd Section.png" alt="Training" onerror="this.style.display='none'" />
                <div class="img-bg-text">A</div>
            </div>
            <div class="about-img about-img-sec">
                <img src="~/images/Redhulk 2nd Section 2.png" alt="Training" onerror="this.style.display='none'" />
                <div class="img-bg-text">B</div>
            </div>
            <div class="about-badge">
                <div class="about-badge-num">10+</div>
                <div class="about-badge-text">Years of<br>Excellence</div>
            </div>
        </div>

        <div class="about-body">
            <div class="eyebrow">
                <div class="eyebrow-line"></div>
                <span class="eyebrow-text">About Us</span>
            </div>
            <h2 class="sec-heading">
                EMPOWERING YOUR<br>
                <span class="accent">FITNESS</span> GOALS
            </h2>
            <p class="lead-text">
                We believe fitness is more than just a workout — it's a lifestyle.
                With top-of-the-line facilities, certified trainers, and a supportive
                community, we're here to inspire and guide you every step of the way.
            </p>

            <div class="about-features">
                <div class="feat">
                    <div class="feat-icon">&#9670;</div>
                    <div><h4>Personal Trainer</h4><p>Achieve your goals with certified trainer guidance.</p></div>
                </div>
                <div class="feat">
                    <div class="feat-icon">&#8862;</div>
                    <div><h4>Group Classes</h4><p>High-energy sessions in a motivating team environment.</p></div>
                </div>
                <div class="feat">
                    <div class="feat-icon">&#9678;</div>
                    <div><h4>Nutrition Plans</h4><p>Custom plans designed around your physique goals.</p></div>
                </div>
                <div class="feat">
                    <div class="feat-icon">&#8853;</div>
                    <div><h4>Recovery Zone</h4><p>Ice baths, saunas, and dedicated recovery facilities.</p></div>
                </div>
            </div>

            <button class="btn-primary-pf">Get Started Today</button>
        </div>
    </section>

    <!-- ══ WORKOUTS ════════════════════════════════════════════════ -->
    <div class="workouts-sec">
        <div class="sec-header">
            <div>
                <div class="eyebrow">
                    <div class="eyebrow-line"></div>
                    <span class="eyebrow-text">Programs</span>
                </div>
                <h2 class="sec-heading">
                    TRANSFORM WITH OUR<br>
                    <span class="accent">WORKOUTS</span>
                </h2>
            </div>
            <a href="#" class="view-all">View All &nbsp;&#8594;</a>
        </div>

        <div class="workouts-grid">
            <div class="wcard">
                <div class="wcard-bg wcard-bg-1"></div>
                <div class="wcard-flair"><span class="wcard-flair-text">GW</span></div>
                <img src="~/images/Redhulk 3rd Section 1.png" alt="Group Workout" onerror="this.style.display='none'" />
                <div class="wcard-overlay"></div>
                <div class="wcard-content">
                    <span class="wcard-tag">Popular</span>
                    <div class="wcard-title">GROUP WORKOUT</div>
                    <div class="wcard-meta"><span>60 min</span><span>·</span><span>All levels</span></div>

                </div>
            </div>

            <div class="wcard">
                <div class="wcard-bg wcard-bg-2"></div>
                <div class="wcard-flair"><span class="wcard-flair-text">PT</span></div>
                <img src="~/images/Redhulk 3rd Section 2.png" alt="Power Training" onerror="this.style.display='none'" />
                <div class="wcard-overlay"></div>
                <div class="wcard-content">
                    <span class="wcard-tag">Intense</span>
                    <div class="wcard-title">POWER TRAINING</div>
                    <div class="wcard-meta"><span>45 min</span><span>·</span><span>Advanced</span></div>
                </div>
            </div>

            <div class="wcard">
                <div class="wcard-bg wcard-bg-3"></div>
                <div class="wcard-flair"><span class="wcard-flair-text">CB</span></div>
                <img src="~/images/Redhulk 3rd Section 3.png" alt="Circuit Blast" onerror="this.style.display='none'" />
                <div class="wcard-overlay"></div>
                <div class="wcard-content">
                    <span class="wcard-tag">New</span>
                    <div class="wcard-title">CIRCUIT BLAST</div>
                    <div class="wcard-meta"><span>30 min</span><span>·</span><span>Beginner</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ WHY US ═════════════════════════════════════════════════ -->
    <section class="whyus-sec">
        <div>
            <div class="eyebrow">
                <div class="eyebrow-line"></div>
                <span class="eyebrow-text">Why Us</span>
            </div>
            <h2 class="sec-heading">
                ELEVATE FITNESS<br>
                THE <span class="accent">BEST</span> WAY
            </h2>
            <p class="whyus-lead">
                We believe fitness is more than just a workout — it's a lifestyle.
                With top-of-the-line facilities, certified trainers, and a supportive
                community, we're here to inspire you every step of the way.
            </p>
            <button class="btn-primary-pf" style="margin-top:2rem;">Join The Community</button>
        </div>

        <ul class="why-list">
            <li class="why-item">
                <div class="why-num">01</div>
                <div class="why-text">
                    <h3>Personalized Fitness Plans</h3>
                    <p>We tailor every workout to fit your unique goals and fitness level, ensuring you make the most progress.</p>
                </div>
            </li>
            <li class="why-item">
                <div class="why-num">02</div>
                <div class="why-text">
                    <h3>Expert Certified Trainers</h3>
                    <p>Our certified professionals bring decades of experience to help you train smarter and recover faster.</p>
                </div>
            </li>
            <li class="why-item">
                <div class="why-num">03</div>
                <div class="why-text">
                    <h3>World-Class Facilities</h3>
                    <p>State-of-the-art equipment, recovery zones, and nutrition bars — everything under one roof.</p>
                </div>
            </li>
        </ul>
    </section>

    <!-- ══ FOOTER TICKER ══════════════════════════════════════════ -->
    <div class="ticker">
        <div class="ticker-track rev">
            <span class="ticker-item">Outdoor &amp; Online Trainers <span class="ticker-dot"></span></span>
            <span class="ticker-item">Personal Training <span class="ticker-dot"></span></span>
            <span class="ticker-item">Live Classes <span class="ticker-dot"></span></span>
            <span class="ticker-item">Personal Trainers <span class="ticker-dot"></span></span>
            <span class="ticker-item">Group Workouts <span class="ticker-dot"></span></span>
            <span class="ticker-item">Nutrition Plans <span class="ticker-dot"></span></span>
            <span class="ticker-item">Outdoor &amp; Online Trainers <span class="ticker-dot"></span></span>
            <span class="ticker-item">Personal Training <span class="ticker-dot"></span></span>
            <span class="ticker-item">Live Classes <span class="ticker-dot"></span></span>
            <span class="ticker-item">Personal Trainers <span class="ticker-dot"></span></span>
            <span class="ticker-item">Group Workouts <span class="ticker-dot"></span></span>
            <span class="ticker-item">Nutrition Plans <span class="ticker-dot"></span></span>
        </div>
    </div>

    <!-- ══ FOOTER ══════════════════════════════════════════════════ -->
    <footer class="site-footer">
        <div class="footer-main">
            <div>
                <div class="footer-logo">POWER<span>FIT</span></div>
                <p class="footer-tagline">Push harder, go further.<br>Your fitness journey starts today.</p>
            </div>
            <div class="footer-col">
                <h4>Contact Us</h4>
                <ul class="footer-list">
                    <li><span class="fi">&#9990;</span> +91 123 456 789</li>
                    <li><span class="fi">&#9993;</span> info@powerfitness.com</li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Gym Timing</h4>
                <ul class="footer-list">
                    <li>Mon &ndash; Fri &nbsp;&nbsp; 08:00 AM &ndash; 10:00 PM</li>
                    <li>Sat &ndash; Sun &nbsp;&nbsp; 08:00 AM &ndash; 09:00 PM</li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Location</h4>
                <ul class="footer-list">
                    <li>2715 Ash Dr. San Jose,<br>South Dakota 83475</li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 PowerFit. All rights reserved.</p>
            <ul class="footer-bottom-links">
                <li><a href="#">Privacy Policy</a></li>
                <li><a href="#">Terms of Service</a></li>
                <li><a href="#">Sitemap</a></li>
            </ul>
        </div>
    </footer>

</div>