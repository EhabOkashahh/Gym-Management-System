@model LoginModelView

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PowerFit</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <div class="auth-wrap">

        <!-- LEFT: HERO SIDE -->
        <div class="auth-left">
            <div class="auth-left-content">
                <a href="/" class="auth-logo">
                    POWER<span>FIT</span>
                </a>

                <h1 class="auth-quote">
                    YOUR BODY CAN<br>
                    <span>STAND ALMOST</span><br>
                    ANYTHING
                </h1>

                <p class="auth-subtext">
                    It's your mind that needs convincing. Push past your limits,
                    stay committed, and watch your body transform into a powerhouse
                    of strength and resilience.
                </p>
            </div>
        </div>

        <!-- RIGHT: FORM SIDE -->
        <div class="auth-right">
            <div class="auth-grid-lines"></div>

            <div class="auth-form-container">

                <div class="auth-header">
                    <h2>Welcome Back</h2>
                    <p>Login to your admin dashboard</p>
                </div>

                <form asp-action="Login" asp-controller="Account" method="post" class="auth-form" id="loginForm">

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="pf-alert error mb-4">
                            @Html.ValidationSummary(true, "")
                        </div>
                    }

                    <div class="form-group">
                        <label asp-for="Email">Email Address</label>
                        <div class="auth-input-wrapper">
                            <i class="bi bi-envelope"></i>
                            <input asp-for="Email" placeholder="Enter your email" autocomplete="username" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password">Password</label>
                        <div class="auth-input-wrapper">
                            <i class="bi bi-lock"></i>
                            <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="auth-check">
                            <input asp-for="RememberMe" type="checkbox" />
                            <span>Keep me logged in</span>
                        </label>
                    </div>

                    <button type="submit" class="btn-primary-pf btn-auth" id="loginBtn">
                        Sign In &nbsp; &#8594;
                    </button>

                </form>

                <div class="auth-footer">
                    <p>Forget your password? <a href="#">Contact Support</a></p>
                </div>

            </div>
        </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validation.unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(function() {
            $('#Email').focus();

            $('#loginForm').on('submit', function () {
                if ($(this).valid()) {
                    const btn = document.getElementById('loginBtn');
                    btn.innerHTML = 'Signing In...';
                    btn.style.opacity = '0.7';
                    btn.disabled = true;
                }
            });
        });
    </script>

</body>

</html>
