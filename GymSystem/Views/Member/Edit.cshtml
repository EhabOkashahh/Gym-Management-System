@model UpdateMemberModelView

@section Styles {
    <link rel="stylesheet" href="~/css/site.css" />
}

<div class="members-page">

    <div class="members-form-wrapper">

        <!-- HEADER -->
        <div class="members-form-header">
            <img src="~/images/@Model.Photo" class="members-form-img" />
            <h2>@Model.Name</h2>
        </div>

        <!-- FORM -->
        <form method="post" class="members-form">

            <input asp-for="Photo" hidden />
            <input asp-for="Name" hidden />

            <div class="members-form-grid">

                <!-- EMAIL -->
                <div class="members-input-box">
                    <small>Email</small>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- PHONE -->
                <div class="members-input-box">
                    <small>Phone</small>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <!-- BUILDING -->
                <div class="members-input-box">
                    <small>Building No</small>
                    <input asp-for="AddressModel.BuildingNo" class="form-control" />
                    <span asp-validation-for="AddressModel.BuildingNo" class="text-danger"></span>
                </div>

                <!-- CITY -->
                <div class="members-input-box">
                    <small>City</small>
                    <input asp-for="AddressModel.City" class="form-control" />
                    <span asp-validation-for="AddressModel.City" class="text-danger"></span>
                </div>

                <!-- STREET -->
                <div class="members-input-box">
                    <small>Street</small>
                    <input asp-for="AddressModel.Street" class="form-control" />
                    <span asp-validation-for="AddressModel.Street" class="text-danger"></span>
                </div>

                <!-- PLAN -->
                <div class="members-input-box full">
                    <small>Membership Plan</small>
                    <select asp-for="PlanID" class="form-control">
                        <option value="">-- Select --</option>
                        @foreach (var Plan in Model.Plans!)
                        {
                            <option value="@Plan.Id">
                                @Plan.Name - @Plan.DurationDays Days - @Plan.Price$
                            </option>
                        }
                    </select>
                    <span asp-validation-for="PlanID" class="text-danger"></span>
                </div>

            </div>

            <!-- ACTIONS -->
            <div class="members-form-actions">

                <a asp-controller="Member" asp-action="Index" class="btn-primary-pf">
                    Back
                </a>

                <button type="submit" class="btn-primary-pf">
                    Save
                </button>

            </div>

        </form>

    </div>

</div>