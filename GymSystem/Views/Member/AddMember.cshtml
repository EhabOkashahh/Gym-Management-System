@model CreateMemberModelView

@{
    ViewData["Title"] = "Add Member";
}

<div class="pf-form-page">

    <!-- HEADER WITH CIRCULAR PREVIEW -->
    <div class="members-form-header text-center mb-5">
        <div class="position-relative d-inline-block">
            <img id="photoPreviewHeader" src="~/Images/Default.png" class="members-details-img" style="width: 160px; height: 160px; cursor: pointer;" onclick="document.getElementById('photoInput').click();" />
            <div class="position-absolute bottom-0 end-0 bg-red text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border: 3px solid var(--black);">
                <i class="bi bi-camera-fill"></i>
            </div>
        </div>
        <h3 class="mt-3">Register New Member</h3>
        <p class="text-muted">Fill in the details below to create a new profile.</p>
    </div>

    @if (ViewData["CreationFailed"] is bool creationFailed && creationFailed)
    {
        <div class="pf-alert error mb-4">
            <i class="bi bi-exclamation-octagon-fill me-2"></i>
            @ViewData["ErrorMessage"]
        </div>
    }

    <form method="post" enctype="multipart/form-data" class="pf-form-card">

        <div asp-validation-summary="ModelOnly" class="pf-alert error mb-4"></div>

        <!-- SECTION 1: NORMAL DATA -->
        <div class="pf-form-section-title">Normal Data (Personal & Membership)</div>

        <div class="pf-form-grid">

            <!-- Hidden File Input triggered by clicking the profile circle -->
            <div class="pf-form-group full">
                <label>Profile Photo</label>
                <input asp-for="PhotoFile" type="file" class="pf-control" id="photoInput" onchange="previewImage(this)" accept="image/*" />
                <span asp-validation-for="PhotoFile" class="text-danger"></span>
                <small class="text-gray d-block mt-2">Click the profile circle above or the button here to upload.</small>
            </div>

            <div class="pf-form-group">
                <label asp-for="Name">Full Name</label>
                <input asp-for="Name" class="pf-control" placeholder="e.g. Alexander Pierce" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" class="pf-control" placeholder="alex@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="Phone">Phone Number</label>
                <input asp-for="Phone" class="pf-control" placeholder="01XXXXXXXXX" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="DateOfBirth">Date of Birth</label>
                <input asp-for="DateOfBirth" class="pf-control" type="date" />
                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="Gender">Gender</label>
                <select asp-for="Gender" class="pf-control" asp-items="Html.GetEnumSelectList<GymSystem.DAL.Entites.Enums.Gender>()">
                    <option value="">Select Gender</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="PlanID">Subscription Plan</label>
                <select asp-for="PlanID" class="pf-control">
                    <option value="">Choose a plan</option>
                    @if (Model.Plans != null)
                    {
                        foreach (var plan in Model.Plans)
                        {
                            <option value="@plan.Id">@plan.Name (@plan.Price EGP)</option>
                        }
                    }
                </select>
                <span asp-validation-for="PlanID" class="text-danger"></span>
            </div>

            <!-- Address Information -->
            <div class="pf-form-group">
                <label asp-for="AddressModel.BuildingNo">Building Number</label>
                <input asp-for="AddressModel.BuildingNo" class="pf-control" placeholder="123" />
                <span asp-validation-for="AddressModel.BuildingNo" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="AddressModel.Street">Street Name</label>
                <input asp-for="AddressModel.Street" class="pf-control" placeholder="Main St." />
                <span asp-validation-for="AddressModel.Street" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="AddressModel.City">City</label>
                <input asp-for="AddressModel.City" class="pf-control" placeholder="Cairo" />
                <span asp-validation-for="AddressModel.City" class="text-danger"></span>
            </div>
        </div>

        <!-- SECTION 2: HEALTH DATA -->
        <div class="pf-form-section-title mt-5">Health Data</div>

        <div class="pf-form-grid">
            <div class="pf-form-group">
                <label asp-for="HealthRecordModelView.Height">Height (cm)</label>
                <input asp-for="HealthRecordModelView.Height" class="pf-control" type="number" step="0.1" placeholder="175" />
                <span asp-validation-for="HealthRecordModelView.Height" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="HealthRecordModelView.Weight">Weight (kg)</label>
                <input asp-for="HealthRecordModelView.Weight" class="pf-control" type="number" step="0.1" placeholder="70" />
                <span asp-validation-for="HealthRecordModelView.Weight" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="HealthRecordModelView.BloodType">Blood Type</label>
                <select asp-for="HealthRecordModelView.BloodType" class="pf-control">
                    <option value="">Select Type</option>
                    <option value="A+">A+</option>
                    <option value="A-">A-</option>
                    <option value="B+">B+</option>
                    <option value="B-">B-</option>
                    <option value="O+">O+</option>
                    <option value="O-">O-</option>
                    <option value="AB+">AB+</option>
                    <option value="AB-">AB-</option>
                </select>
                <span asp-validation-for="HealthRecordModelView.BloodType" class="text-danger"></span>
            </div>

            <div class="pf-form-group full">
                <label asp-for="HealthRecordModelView.Note">Medical Notes</label>
                <textarea asp-for="HealthRecordModelView.Note" class="pf-control" rows="3" placeholder="Medical conditions, allergies, or fitness goals..."></textarea>
                <span asp-validation-for="HealthRecordModelView.Note" class="text-danger"></span>
            </div>
        </div>

        <!-- ACTIONS -->
        <div class="pf-form-actions">
            <a asp-action="Index" class="btn-outline-pf">
                <i class="bi bi-arrow-left me-2"></i> Cancel
            </a>
            <button type="submit" class="btn-primary-pf">
                Register Member <i class="bi bi-person-plus-fill ms-2"></i>
            </button>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            const preview = document.getElementById('photoPreviewHeader');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
