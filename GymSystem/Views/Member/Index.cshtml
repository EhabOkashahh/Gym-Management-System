@model IEnumerable<MemberModelView>

@{
    var activeMembers = Model.Where(m => !m.IsDeleted).ToList();
    var deletedMembers = Model.Where(m => m.IsDeleted).ToList();
    ViewData["Title"] = "Members";
}

@section Styles {
    <link rel="stylesheet" href="~/css/site.css" />
}

<div class="members-page">

    <!-- HEADER -->
    <div class="members-header">
        <a asp-action="AddMember" class="btn-primary-pf">
            + Add Member
        </a>
    </div>

    <!-- TABS -->
    <div class="members-tabs">

        <button class="members-tab active" data-tab="active">
            Active Members
        </button>

        <button class="members-tab" data-tab="deleted">
            Deleted Members
        </button>

    </div>

    <!-- ACTIVE -->
    <div class="members-section active" id="active">

        @if (activeMembers.Any())
        {
            <div class="members-table">

                <table>

                    <thead>
                        <tr>
                            <th>Photo</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var member in activeMembers)
                        {
                            <tr>

                                <td>
                                    <img src="~/images/@member.Photo" />
                                </td>

                                <td>@member.Name</td>
                                <td>@member.Email</td>
                                <td>@member.Gender</td>
                                <td>@member.Phone</td>
                                <td>@member.IsDeleted</td>

                                <!-- ACTIONS FIXED -->
                                <td>

                                    <div class="members-actions">

                                        <!-- 3 DOT BUTTON -->
                                        <button type="button"
                                                class="members-menu-btn"
                                                onclick="toggleMenu(this)">
                                            ⋮
                                        </button>

                                        <!-- MENU -->
                                        <div class="members-menu">

                                            <a asp-action="MemberDetails"
                                               asp-route-Id="@member.Id">
                                                View Member
                                            </a>

                                            <a asp-action="ViewHealthRecordData"
                                               asp-route-Id="@member.Id">
                                                Health Record
                                            </a>

                                            <a asp-action="Edit"
                                               asp-route-Id="@member.Id">
                                                Edit
                                            </a>

                                            <button class="danger"
                                                    onclick="setSoftDeleteId(@member.Id)">
                                                Soft Delete
                                            </button>

                                        </div>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="empty-state">No Active Members</div>
        }

    </div>

    <!-- DELETED -->
    <div class="members-section" id="deleted">

        @if (deletedMembers.Any())
        {
            <div class="members-table">

                <table>

                    <thead>
                        <tr>
                            <th>Photo</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var member in deletedMembers)
                        {
                            <tr class="muted">

                                <td>
                                    <img src="~/images/@member.Photo" />
                                </td>

                                <td>@member.Name</td>
                                <td>@member.Email</td>
                                <td>@member.Gender</td>
                                <td>@member.Phone</td>
                                <td>@member.IsDeleted</td>

                                <td>
                                    <button class="restore-btn"
                                            onclick="setRestoreId(@member.Id)">
                                        Restore
                                    </button>
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="empty-state">No Deleted Members</div>
        }

    </div>

</div>

<!-- hidden forms -->
<div class="hidden">
    <form asp-action="SoftDeleteMember" method="post">
        <input type="hidden" id="SoftDeleteMemberId" name="Id" />
    </form>

    <form asp-action="RestoreMember" method="post">
        <input type="hidden" id="RestoreMemberId" name="Id" />
    </form>
</div>

@section Scripts {

    <script>
        // restore + soft delete
        function setRestoreId(id) {
            document.getElementById("RestoreMemberId").value = id;
        }

        function setSoftDeleteId(id) {
            document.getElementById("SoftDeleteMemberId").value = id;
        }

        // TAB SWITCH
        document.querySelectorAll(".members-tab").forEach(btn => {
            btn.addEventListener("click", () => {

                document.querySelectorAll(".members-tab").forEach(b => b.classList.remove("active"));
                document.querySelectorAll(".members-section").forEach(s => s.classList.remove("active"));

                btn.classList.add("active");
                document.getElementById(btn.dataset.tab).classList.add("active");
            });
        });

        // DROPDOWN TOGGLE (FIX)
        function toggleMenu(btn) {

            const menu = btn.nextElementSibling;

            // close others
            document.querySelectorAll(".members-menu").forEach(m => {
                if (m !== menu) m.classList.remove("active-flex");
            });

            // toggle current
            menu.classList.toggle("active-flex");
        }

        // close on outside click
        document.addEventListener("click", function (e) {
            if (!e.target.closest(".members-actions")) {
                document.querySelectorAll(".members-menu")
                    .forEach(m => m.classList.remove("active-flex"));
            }
        });
    </script>
}