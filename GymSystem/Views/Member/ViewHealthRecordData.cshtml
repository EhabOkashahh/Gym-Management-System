@model HealthRecordModelView

@{
    ViewData["Title"] = "Health Record";
}

<div class="session-details-page">

    <div class="session-details-header">
        <h3>Health Record</h3>
        <p>Member's physical metrics and health information</p>
    </div>

    <div class="session-details-card">
        
        <!-- Header -->
        <div class="card-header">
            <i class="bi bi-heart-pulse display-1 text-red mb-3 d-block"></i>
            <h2 class="session-details-title">Physical Metrics</h2>
            <span class="session-details-badge pf-alert success">
                Updated Recently
            </span>
        </div>

        <div class="p-4">
            
            <div class="session-details-grid">
                
                <div class="session-details-item">
                    <i class="bi bi-rulers"></i>
                    <div>
                        <small>Height</small>
                        <strong>@Model.Height cm</strong>
                    </div>
                </div>

                <div class="session-details-item">
                    <i class="bi bi-speedometer2"></i>
                    <div>
                        <small>Weight</small>
                        <strong>@Model.Weight kg</strong>
                    </div>
                </div>

                <div class="session-details-item">
                    <i class="bi bi-droplet-fill"></i>
                    <div>
                        <small>Blood Type</small>
                        <strong class="text-red">@Model.BloodType</strong>
                    </div>
                </div>

                <div class="session-details-item full">
                    <i class="bi bi-journal-text"></i>
                    <div>
                        <small>Health Notes</small>
                        <strong>@(string.IsNullOrEmpty(Model.Note) ? "No special health notes provided." : Model.Note)</strong>
                    </div>
                </div>

            </div>

            <div class="session-details-actions">
                <a asp-controller="Member" asp-action="Index" class="btn-outline-pf">
                    Back to Members
                </a>
            </div>

        </div>

    </div>

</div>
