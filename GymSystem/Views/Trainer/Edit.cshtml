@model UpdateTrainerModelView

@{
    ViewData["Title"] = "Edit Trainer";
}

<div class="pf-form-page">

    <div class="pf-form-header">
        <h3>Edit Trainer</h3>
        <p class="text-muted">Update trainer information</p>
    </div>

    <form asp-action="Edit" method="post" class="pf-form-card">
        
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="pf-alert error mb-4"></div>

        <!-- Personal Info -->
        <div class="pf-form-section-title">Personal Information</div>
        <div class="pf-form-grid">
            
            <div class="pf-form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="pf-control" placeholder="email@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="Phone"></label>
                <input asp-for="Phone" class="pf-control" placeholder="+1 (555) 000-0000" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>
        </div>

        <!-- Address Info -->
        <div class="pf-form-section-title">Address Information</div>
        <div class="pf-form-grid">
            
            <div class="pf-form-group">
                <label asp-for="Address.BuildingNo"></label>
                <input asp-for="Address.BuildingNo" class="pf-control" placeholder="Building #" />
                <span asp-validation-for="Address.BuildingNo" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="Address.Street"></label>
                <input asp-for="Address.Street" class="pf-control" placeholder="Street Name" />
                <span asp-validation-for="Address.Street" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="Address.City"></label>
                <input asp-for="Address.City" class="pf-control" placeholder="City" />
                <span asp-validation-for="Address.City" class="text-danger"></span>
            </div>
        </div>

        <!-- Professional Info -->
        <div class="pf-form-section-title">Professional Information</div>
        <div class="pf-form-grid">
            
            <div class="pf-form-group full">
                <label asp-for="Specialization">Specialization</label>
                <div class="d-flex flex-wrap gap-4 mt-2">
                    <div class="pf-check">
                        <input type="radio" asp-for="Specialization" value="GeneralFitness" id="spec1" />
                        <label for="spec1" class="m-0 ms-2">General Fitness</label>
                    </div>
                    <div class="pf-check">
                        <input type="radio" asp-for="Specialization" value="Yoga" id="spec2" />
                        <label for="spec2" class="m-0 ms-2">Yoga</label>
                    </div>
                    <div class="pf-check">
                        <input type="radio" asp-for="Specialization" value="Boxing" id="spec3" />
                        <label for="spec3" class="m-0 ms-2">Boxing</label>
                    </div>
                    <div class="pf-check">
                        <input type="radio" asp-for="Specialization" value="CrossFit" id="spec4" />
                        <label for="spec4" class="m-0 ms-2">CrossFit</label>
                    </div>
                </div>
                <span asp-validation-for="Specialization" class="text-danger"></span>
            </div>
        </div>

        <div class="pf-form-actions">
            <a asp-action="Index" class="btn-outline-pf">Cancel</a>
            <button type="submit" class="btn-primary-pf">Update Trainer</button>
        </div>

    </form>

</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
