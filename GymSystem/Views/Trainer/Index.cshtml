@model IEnumerable<TrainerModelView>

@{
    var activeTrainers = Model.Where(t => !t.IsDeleted).ToList();
    var deletedTrainers = Model.Where(t => t.IsDeleted).ToList();
    ViewData["Title"] = "Trainers";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <title>Power Fitness | Trainers</title>

    <style>
        /* FIX: allow dropdown to escape responsive container */
        .trainers-table-wrapper .table-responsive {
            overflow-x: visible;
        }

        /* Ensure dropdown appears above everything */
        .dropdown-menu {
            z-index: 1055;
            border-radius: 10px;
            box-shadow: 0 8px 24px rgba(0,0,0,.12);
        }
    </style>
</head>
<body>
<div class="container">
    <main class="pb-3">

        <!-- Add Trainer Button -->
        <header class="d-flex justify-content-end mt-4 mb-4">
            <a asp-action="AddTrainer" class="btn btn-fill fw-medium rounded-pill px-3 py-3">
                + Add Trainer
            </a>
        </header>

        <!-- Tabs -->
        <ul class="nav nav-tabs" id="trainerTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#active">
                    Active Trainers
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#deleted">
                    Deleted Trainers
                </button>
            </li>
        </ul>

        <!-- Tabs Content -->
        <div class="tab-content mt-3">

            <!-- ACTIVE -->
            <div class="tab-pane fade show active" id="active">
                @if (activeTrainers.Any())
                {
                    <div class="trainers-table-wrapper">
                        <div class="table-responsive">
                            <table class="table table-borderless align-middle">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Gender</th>
                                        <th>Phone</th>
                                        <th>Specialization</th>
                                        <th>IsDeleted</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var trainer in activeTrainers)
                                {
                                    <tr>
                                        <td>@trainer.Name</td>
                                        <td>@trainer.Email</td>
                                        <td>@trainer.Gender</td>
                                        <td>@trainer.Phone</td>
                                        <td>@trainer.Specialization</td>
                                        <td>@trainer.IsDeleted</td>
                                        <td>
                                            <div class="dropdown position-static">
                                                <button class="btn btn-link p-0 border-0"
                                                        data-bs-toggle="dropdown">
                                                    <img src="~/images/action dots.jpg" />
                                                </button>

                                                <ul class="dropdown-menu">
                                                    <li>
                                                        <a asp-action="Details"
                                                           asp-route-Id="@trainer.Id"
                                                           class="dropdown-item">
                                                            View Trainer Details
                                                        </a>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <a asp-action="Edit"
                                                           asp-route-Id="@trainer.Id"
                                                           class="dropdown-item">
                                                            Edit Trainer Data
                                                        </a>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <a asp-action="SoftDelete"
                                                           asp-route-Id="@trainer.Id"
                                                           class="dropdown-item text-danger">
                                                            Soft Delete
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <h4>No Active Trainers</h4>
                    </div>
                }
            </div>

            <!-- DELETED -->
            <div class="tab-pane fade" id="deleted">
                @if (deletedTrainers.Any())
                {
                    <div class="trainers-table-wrapper">
                        <div class="table-responsive">
                            <table class="table table-borderless align-middle">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Gender</th>
                                        <th>Phone</th>
                                        <th>Specialization</th>
                                        <th>IsDeleted</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var trainer in deletedTrainers)
                                {
                                    <tr class="text-muted">
                                        <td>@trainer.Name</td>
                                        <td>@trainer.Email</td>
                                        <td>@trainer.Gender</td>
                                        <td>@trainer.Phone</td>
                                        <td>@trainer.Specialization</td>
                                        <td>@trainer.IsDeleted</td>
                                        <td>
                                            <div class="dropdown position-static">
                                                <button class="btn btn-link p-0 border-0"
                                                        data-bs-toggle="dropdown">
                                                    <img src="~/images/action dots.jpg" />
                                                </button>

                                                <ul class="dropdown-menu">
                                                    <li>
                                                            <button class="dropdown-item text-success"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#RestoreModal"
                                                            onclick="setTrainerId(@trainer.Id)">
                                                                RestoreMember
                                                            </button>
                                                    </li>
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <h4>No Deleted Trainers</h4>
                    </div>
                }
            </div>

        </div>


         @* RestoreMember Confirmation *@
    <div class="modal fade" id="RestoreModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Restore</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to restore this member ?
            </div>

            <div class="modal-footer">
                <form asp-action="RestoreTrainer" method="post">
                    <input type="hidden" id="RenewTrainerId" name="id" />
                    <button type="submit" class="btn btn-light">Yes, Restore</button>
                </form>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
            </div>

        </div>
    </div>
    </main>
</div>
<script>
    function setTrainerId(id) {
        document.getElementById("RenewTrainerId").value = id;
    }
</script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>