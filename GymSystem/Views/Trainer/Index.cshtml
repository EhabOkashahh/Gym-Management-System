@model IEnumerable<TrainerModelView>

@{
    var activeTrainers = Model.Where(t => !t.IsDeleted).ToList();
    var deletedTrainers = Model.Where(t => t.IsDeleted).ToList();
    ViewData["Title"] = "Trainers";
}

<div class="trainers-page">

    <!-- HEADER -->
    <div class="trainers-header">
        <a asp-action="AddTrainer" class="btn-primary-pf">
            + Add Trainer
        </a>
    </div>

    <!-- TABS -->
    <div class="trainers-tabs">
        <button class="trainers-tab active" data-tab="active">
            Active Trainers
        </button>
        <button class="trainers-tab" data-tab="deleted">
            Deleted Trainers
        </button>
    </div>

    <!-- ACTIVE -->
    <div class="trainers-section active" id="active">
        @if (activeTrainers.Any())
        {
            <div class="trainers-table">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th>Specialization</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trainer in activeTrainers)
                        {
                            <tr>
                                <td>@trainer.Name</td>
                                <td>@trainer.Email</td>
                                <td>@trainer.Gender</td>
                                <td>@trainer.Phone</td>
                                <td>@trainer.Specialization</td>
                                <td>Active</td>
                                <td>
                                    <div class="trainers-actions">
                                        <button type="button" class="trainers-menu-btn" onclick="toggleTrainerMenu(this)">
                                            ⋮
                                        </button>
                                        <div class="trainers-menu">
                                            <a asp-action="Details" asp-route-Id="@trainer.Id">View Details</a>
                                            <a asp-action="Edit" asp-route-Id="@trainer.Id">Edit Data</a>
                                            <button class="danger" onclick="setSoftDeleteId(@trainer.Id)">Soft Delete</button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">No Active Trainers Found</div>
        }
    </div>

    <!-- DELETED -->
    <div class="trainers-section" id="deleted">
        @if (deletedTrainers.Any())
        {
            <div class="trainers-table">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th>Specialization</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trainer in deletedTrainers)
                        {
                            <tr class="muted">
                                <td>@trainer.Name</td>
                                <td>@trainer.Email</td>
                                <td>@trainer.Gender</td>
                                <td>@trainer.Phone</td>
                                <td>@trainer.Specialization</td>
                                <td>
                                    <button class="restore-btn" onclick="setRestoreId(@trainer.Id)">
                                        Restore
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">No Deleted Trainers</div>
        }
    </div>

</div>

<!-- HIDDEN FORMS -->
<form asp-action="SoftDelete" method="post" id="softDeleteForm" style="display:none">
    <input type="hidden" id="softDeleteId" name="id" />
</form>

<form asp-action="RestoreTrainer" method="post" id="restoreForm" style="display:none">
    <input type="hidden" id="restoreId" name="id" />
</form>

@section Scripts {
    <script>
        function setSoftDeleteId(id) {
            if (confirm("Are you sure you want to soft delete this trainer?")) {
                document.getElementById("softDeleteId").value = id;
                document.getElementById("softDeleteForm").submit();
            }
        }

        function setRestoreId(id) {
            document.getElementById("restoreId").value = id;
            document.getElementById("restoreForm").submit();
        }

        // TAB SWITCH
        document.querySelectorAll(".trainers-tab").forEach(btn => {
            btn.addEventListener("click", () => {
                document.querySelectorAll(".trainers-tab").forEach(b => b.classList.remove("active"));
                document.querySelectorAll(".trainers-section").forEach(s => s.classList.remove("active"));
                btn.classList.add("active");
                document.getElementById(btn.dataset.tab).classList.add("active");
            });
        });

        // DROPDOWN TOGGLE
        function toggleTrainerMenu(btn) {
            const menu = btn.nextElementSibling;
            document.querySelectorAll(".trainers-menu").forEach(m => {
                if (m !== menu) m.classList.remove("active-flex");
            });
            menu.classList.toggle("active-flex");
        }

        document.addEventListener("click", function (e) {
            if (!e.target.closest(".trainers-actions")) {
                document.querySelectorAll(".trainers-menu").forEach(m => m.classList.remove("active-flex"));
            }
        });
    </script>
}
