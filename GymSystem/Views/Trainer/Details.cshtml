@model TrainerDetailsModelView

@{
    ViewData["Title"] = "Trainer Details";
}

<div class="session-details-page">

    <div class="session-details-header">
        <h3>Trainer Profile</h3>
        <p>Comprehensive trainer information and details</p>
    </div>

    <div class="session-details-card">
        
        <!-- Status Area -->
        <div class="card-header">
            <i class="bi bi-person-badge display-1 text-red mb-3 d-block"></i>
            <h2 class="session-details-title">@Model.Name</h2>
            <span class="session-details-badge pf-alert success">
                @Model.Specialization Trainer
            </span>
        </div>

        <div class="p-4">
            
            <div class="session-details-grid">
                
                <div class="session-details-item">
                    <i class="bi bi-envelope"></i>
                    <div>
                        <small>Email Address</small>
                        <strong>@Model.Email</strong>
                    </div>
                </div>

                <div class="session-details-item">
                    <i class="bi bi-telephone"></i>
                    <div>
                        <small>Phone Number</small>
                        <strong>@Model.Phone</strong>
                    </div>
                </div>

                <div class="session-details-item">
                    <i class="bi bi-calendar-event"></i>
                    <div>
                        <small>Date of Birth</small>
                        <strong>@Model.DateOfBirth.ToShortDateString()</strong>
                    </div>
                </div>

                <div class="session-details-item full">
                    <i class="bi bi-geo-alt"></i>
                    <div>
                        <small>Location / Address</small>
                        <strong>@Model.Address.BuildingNo, @Model.Address.Street, @Model.Address.City</strong>
                    </div>
                </div>

            </div>

            <div class="session-details-actions">
                <a asp-action="Index" class="btn-outline-pf">
                    Back to List
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-pf">
                    Edit Profile
                </a>
            </div>

        </div>

    </div>

</div>
