@model ChatModel
@{
    Layout = null;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
    var currentUserName = User.Identity?.Name ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Support Chat - PowerFit</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --chat-sidebar-width: 280px;
            --chat-header-height: 70px;
            --chat-input-height: 80px;
        }

        body {
            background: var(--black);
            margin: 0;
            padding: 0;
            overflow: hidden;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .chat-layout {
            display: flex;
            width: 100vw;
            height: 100vh;
            background: var(--black);
            position: relative;
        }

        /* ── Sidebar ── */
        .chat-sidebar {
            width: var(--chat-sidebar-width);
            background: var(--dark);
            border-right: 1px solid rgba(255,255,255,0.06);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            transition: transform 0.3s;
        }

        .sidebar-header {
            padding: 2rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .sidebar-header h2 {
            font-family: var(--font-display);
            font-size: 2rem;
            letter-spacing: 0.04em;
            margin: 0;
        }

        .sidebar-header p {
            font-size: 0.75rem;
            color: var(--gray);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-top: 0.4rem;
        }

        .chat-list {
            flex: 1;
            overflow-y: auto;
            padding: 1rem 0;
        }

        .chat-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.5rem;
            cursor: pointer;
            transition: background 0.2s;
            border-left: 3px solid transparent;
        }

            .chat-item:hover {
                background: var(--dark2);
            }

            .chat-item.active {
                background: var(--dark3);
                border-left-color: var(--red);
            }

        .chat-item-avatar {
            width: 42px;
            height: 42px;
            background: var(--dark3);
            border: 1px solid rgba(255,255,255,0.1);
            color: var(--red);
            font-family: var(--font-display);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .chat-item-info {
            flex: 1;
            min-width: 0;
        }

        .chat-item-name {
            font-family: var(--font-condensed);
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--white);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .chat-item-last {
            font-size: 0.75rem;
            color: var(--gray);
            margin-top: 0.2rem;
        }

        .close-ticket-btn {
            opacity: 0;
            background: none;
            border: none;
            color: var(--gray);
            cursor: pointer;
            transition: opacity 0.2s, color 0.2s;
        }

        .chat-item:hover .close-ticket-btn {
            opacity: 1;
        }

        .close-ticket-btn:hover {
            color: var(--red);
        }

        /* ── Main Chat Area ── */
        .chat-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--black);
            min-width: 0;
            position: relative;
        }

        .chat-main-header {
            height: var(--chat-header-height);
            padding: 0 2rem;
            display: flex;
            align-items: center;
            gap: 1.2rem;
            background: var(--dark);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            flex-shrink: 0;
        }

        .active-chat-avatar {
            width: 44px;
            height: 44px;
            background: var(--red);
            color: var(--white);
            font-family: var(--font-display);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
        }

        .active-chat-info h3 {
            font-family: var(--font-display);
            font-size: 1.5rem;
            margin: 0;
            letter-spacing: 0.02em;
        }

        .active-chat-status {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--green);
            margin-top: 0.1rem;
        }

        /* ── Messages ── */
        .chat-messages-container {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        .message-row {
            display: flex;
            flex-direction: column;
            max-width: 75%;
        }

            .message-row.mine {
                align-self: flex-end;
                align-items: flex-end;
            }

            .message-row.theirs {
                align-self: flex-start;
                align-items: flex-start;
            }

        .message-bubble {
            padding: 1rem 1.25rem;
            font-size: 0.95rem;
            line-height: 1.5;
            position: relative;
        }

        .message-row.mine .message-bubble {
            background: var(--red);
            color: var(--white);
            clip-path: polygon(10px 0%, 100% 0%, 100% 100%, 0% 100%);
        }

        .message-row.theirs .message-bubble {
            background: var(--dark3);
            color: var(--gray-light);
            clip-path: polygon(0% 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
        }

        .message-info {
            font-family: var(--font-condensed);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--gray);
            margin-top: 0.5rem;
        }

        /* ── Input ── */
        .chat-input-area {
            height: var(--chat-input-height);
            padding: 0 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            background: var(--dark);
            border-top: 1px solid rgba(255,255,255,0.06);
            flex-shrink: 0;
        }

        .chat-input-area textarea {
            flex: 1;
            background: var(--dark3);
            border: 1px solid rgba(255,255,255,0.1);
            color: var(--white);
            padding: 0.8rem 1.2rem;
            font-family: var(--font-body);
            font-size: 0.9rem;
            resize: none;
            outline: none;
            max-height: 50px;
            transition: border-color 0.2s;
        }

            .chat-input-area textarea:focus {
                border-color: var(--red);
            }

        .chat-send-btn {
            width: 48px;
            height: 48px;
            background: var(--red);
            color: var(--white);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            transition: background 0.2s, transform 0.1s;
        }

            .chat-send-btn:hover {
                background: var(--red-light);
                transform: scale(1.05);
            }

        .chat-empty {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--dark3);
            text-align: center;
        }

            .chat-empty i {
                font-size: 6rem;
                margin-bottom: 1.5rem;
            }

            .chat-empty p {
                font-family: var(--font-display);
                font-size: 2rem;
                letter-spacing: 0.05em;
                color: var(--gray);
            }

        /* ── Scrollbar ── */
        .chat-messages-container::-webkit-scrollbar { width: 4px; }
        .chat-messages-container::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }

        @@media (max-width: 800px) {
            .chat-sidebar {
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                z-index: 100;
                transform: translateX(-100%);
            }
            .chat-sidebar.open {
                transform: translateX(0);
            }
        }
    </style>
</head>
<body>

    <div class="chat-layout">

        <!-- SIDEBAR -->
        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
        {
            <div class="chat-sidebar" id="sidebar">
                <div class="sidebar-header">
                    <h2>Support</h2>
                    <p>@Model.Chats.Count() Active Conversations</p>
                </div>
                <div class="chat-list">
                    @foreach (var chat in Model.Chats)
                    {
                        var initials = chat.User.UserName.Length >= 2
                            ? chat.User.UserName.Substring(0, 2).ToUpper()
                            : chat.User.UserName.ToUpper();
                            
                        <div class="chat-item" onclick="switchGroup(this, @chat.Id, '@chat.User.UserName', '@initials')">
                            <div class="chat-item-avatar">@initials</div>
                            <div class="chat-item-info">
                                <div class="chat-item-name">@chat.User.UserName</div>
                                <div class="chat-item-last">Support ticket #@chat.Id</div>
                            </div>
                            <button class="close-ticket-btn" onclick="closeSidebarChat(event, @chat.Id, this)">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- MAIN AREA -->
        <div class="chat-main">
            
            <div class="chat-main-header">
                <div class="active-chat-avatar" id="header-avatar">
                    <i class="bi bi-chat-dots"></i>
                </div>
                <div class="active-chat-info">
                    <h3 id="chat-title">
                        @(User.IsInRole("Admin") || User.IsInRole("SuperAdmin") ? "Select Conversation" : "PowerFit Support")
                    </h3>
                    <div class="active-chat-status" id="chat-status">
                        @(User.IsInRole("Admin") || User.IsInRole("SuperAdmin") ? "Offline" : "Online")
                    </div>
                </div>
            </div>

            <div class="chat-messages-container" id="messages">
                <div class="chat-empty" id="empty-state">
                    <i class="bi bi-chat-left-dots"></i>
                    <p>Welcome to PowerFit Support</p>
                </div>
            </div>

            <div class="chat-input-area" id="chat-input-container" style="display: none;">
                <textarea id="msg-input" placeholder="Enter your message..." rows="1"
                          onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
                <button class="chat-send-btn" onclick="sendMessage()" title="Send Message">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>

        </div>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <script>
        let chatId = null;
        const ME = @Json.Serialize(currentUserName);

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        connection.start().then(() => {
            const isAdmin = @Json.Serialize(User.IsInRole("Admin") || User.IsInRole("SuperAdmin"));
            if (!isAdmin) {
                chatId = @Model.ChatId;
                if (chatId) {
                    hideEmpty();
                    connection.invoke("JoinChat", chatId);
                    GetUserMessages(chatId);
                }
            }
        }).catch(err => console.error("SignalR connection error:", err));

        connection.on("ReceiveMessage", (data) => {
            hideEmpty();
            appendMessage(data.userName, data.msg, data.sentAt);
        });

        connection.on("NewMessage", (data) => {
            const isAdmin = @Json.Serialize(User.IsInRole("Admin") || User.IsInRole("SuperAdmin"));
            if (!isAdmin) return;
            // Optionally refresh sidebar or add new item
            location.reload(); 
        });

        function appendMessage(user, msg, time) {
            const isMe = user === ME;
            const side = isMe ? 'mine' : 'theirs';
            const initials = (user || '?').substring(0, 2).toUpperCase();
            
            const html = `
                <div class="message-row ${side}">
                    <div class="message-bubble">${escapeHtml(msg)}</div>
                    <div class="message-info">${isMe ? 'You' : user} • ${formatTime(time)}</div>
                </div>
            `;
            
            const container = document.getElementById('messages');
            container.insertAdjacentHTML('beforeend', html);
            container.scrollTop = container.scrollHeight;
        }

        function sendMessage() {
            const input = document.getElementById('msg-input');
            const text = input.value.trim();
            if (!text || !chatId) return;
            connection.invoke("SendMessage", chatId, text);
            input.value = '';
            input.style.height = 'auto';
        }

        async function switchGroup(el, id, name, initials) {
            document.querySelectorAll('.chat-item').forEach(i => i.classList.remove('active'));
            el.classList.add('active');
            chatId = id;

            document.getElementById('header-avatar').innerHTML = initials;
            document.getElementById('chat-title').innerText = name;
            document.getElementById('chat-status').innerText = "Online";
            
            const container = document.getElementById("messages");
            container.innerHTML = "";
            
            const response = await fetch(`/Chat/GetMessages?chatId=${chatId}`);
            const messages = await response.json();
            
            hideEmpty();
            messages.forEach(m => appendMessage(m.userName, m.msg, m.sentAt));
            connection.invoke("JoinChat", chatId);
        }

        async function GetUserMessages(id) {
            const response = await fetch(`/Chat/GetMessages?chatId=${id}`);
            const messages = await response.json();
            hideEmpty();
            messages.forEach(m => appendMessage(m.userName, m.msg, m.sentAt));
        }

        async function closeSidebarChat(e, id, btn) {
            e.stopPropagation();
            if (!confirm("Close this support ticket?")) return;

            const response = await fetch(`/Chat/CloseTicket?chatId=${id}`, { method: "POST" });
            if (response.ok) {
                btn.closest('.chat-item').remove();
                if (chatId === id) location.reload();
            }
        }

        function hideEmpty() { 
            const el = document.getElementById('empty-state'); 
            if (el) el.style.display = 'none'; 
            const inputCont = document.getElementById('chat-input-container');
            if (inputCont) inputCont.style.display = 'flex';
        }
        function handleKey(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } }
        function autoResize(el) { el.style.height = 'auto'; el.style.height = (el.scrollHeight) + 'px'; }
        function formatTime(t) {
            const d = t ? new Date(t) : new Date();
            return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }
        function escapeHtml(t) { return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    </script>
</body>
</html>
