@model IEnumerable<MemberShipModelView>

<div class="container-fluid mt-5">

    <!-- HEADER -->
    <header class="bg-primary text-white rounded-3 p-4 shadow-sm mb-4">
        <h2 class="mb-1 fw-semibold">Active Memberships</h2>
        <p class="mb-0 text-light opacity-75">Members That Have Active Plans</p>
    </header>

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="card-body">

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Member</th>
                                <th>Plan</th>
                                <th>Created</th>
                                <th>Start</th>
                                <th>End</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var ms in Model)
                            {
                                var status = ms.ComputedStatus;
                                var AllStatus = ms.MemberShipStatus;

                                string rowClass =
                                    AllStatus == MemberShipStatus.Active ? "table-success" :
                                    AllStatus == MemberShipStatus.Expired ? "table-warning" :
                                    AllStatus == MemberShipStatus.Canceled ? "table-danger" :
                                    AllStatus == MemberShipStatus.InTrashCan ? "table-info": 
                                    "";

                                bool canRenew = status == MemberShipStatus.Active;

                                <tr class="@rowClass">

                                    <td>@string.Join(", ", ms.Members.Select(m => m.Name))</td>
                                    <td>@ms.Plan.Name</td>
                                    <td>@ms.CreatedAt</td>
                                    <td>@ms.StartDate</td>
                                    <td>@ms.EndDate</td>

                                    <!-- STATUS -->
                                    <td>
                                        <span class="badge @MemberShip.ToBadgeClass(AllStatus)">
                                            @MemberShip.GetDisplayName(AllStatus)
                                        </span>
                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-center">

                                        <!-- TOGGLE CANCEL / ACTIVATE -->
                                        <button class="btn btn-sm @(status == MemberShipStatus.Canceled ? "btn-success" : "btn-danger")"
                                                data-bs-toggle="modal"
                                                data-bs-target="#toggleModal"
                                                onclick="setToggleMembership(@ms.Id, '@status')"
                                                disabled="@(canRenew ? null : "disabled")">
                                            @(status == MemberShipStatus.Canceled ? "Activate" : "Cancel")
                                        </button>

                                        <!-- RENEW -->
                                        <button class="btn btn-sm btn-light"
                                                data-bs-toggle="modal"
                                                data-bs-target="#renewModal"
                                                onclick="setRenewMembership(@ms.Id, '@ms.EndDate:yyyy-MM-dd')"
                                                disabled="@(canRenew ? null : "disabled")">
                                            Renew
                                        </button>

                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <h4>No Active Memberships Available</h4>
                </div>
            }

        </div>
    </div>
</div>

<!-- TOGGLE MODAL -->
<div class="modal fade" id="toggleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="toggleTitle">Confirm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="toggleBody"></div>

            <div class="modal-footer">
                <form asp-controller="Membership"
                      asp-action="ToggleCancelMemberShip"
                      method="post">
                    <input type="hidden" id="toggleMembershipId" name="id" />
                    <button type="submit" id="toggleBtn" class="btn">Confirm</button>
                </form>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
            </div>

        </div>
    </div>
</div>

<!-- RENEW MODAL -->
<div class="modal fade" id="renewModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Renew</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="renewBody"></div>

            <div class="modal-footer">
                <form asp-action="RenewMemberShip" method="post">
                    <input type="hidden" id="renewMembershipId" name="id" />
                    <button type="submit" class="btn btn-light">Yes, Renew</button>
                </form>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {

<script>
    function setToggleMembership(id, status) {

        document.getElementById("toggleMembershipId").value = id;

        const title = document.getElementById("toggleTitle");
        const body = document.getElementById("toggleBody");
        const btn = document.getElementById("toggleBtn");

        if (status === "Canceled") {
            title.innerText = "Activate Membership";
            body.innerText = "Are you sure you want to activate this membership?";
            btn.className = "btn btn-success";
            btn.innerText = "Yes, Activate";
        } else {
            title.innerText = "Cancel Membership";
            body.innerText = "Are you sure you want to cancel this membership?";
            btn.className = "btn btn-danger";
            btn.innerText = "Yes, Cancel";
        }
    }

    function setRenewMembership(id, endDate) {

        document.getElementById("renewMembershipId").value = id;

        const end = new Date(endDate);
        const now = new Date();

        const diffDays = Math.ceil((end - now) / (1000 * 60 * 60 * 24));

        let msg = "";

        if (diffDays > 0)
            msg = `Are you sure you want early renew? Subscription still has ${diffDays} days.`;
        else
            msg = "Are you sure you want to renew this expired membership?";

        document.getElementById("renewBody").innerText = msg;
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

}