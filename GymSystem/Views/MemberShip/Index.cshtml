        @model IEnumerable<MemberShipModelView>

<div class="container-fluid">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- HEADER -->
    <header class="bg-primary text-white rounded-3 p-4 shadow-sm mt-5 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1 fw-semibold">Active Memberships</h2>
                <p class="mb-0 text-light opacity-75">Members That Have Active Plans</p>
            </div>
        </div>
    </header>

    <!-- ALERTS -->
    <div id="successAlert" class="alert alert-success alert-dismissible fade show d-none">
        <i class="bi bi-check-circle-fill me-2"></i> Success Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    <div id="errorAlert" class="alert alert-danger alert-dismissible fade show d-none">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> Error Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Member</th>
                                <th>Plan</th>
                                <th>Created Date</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                       <tbody>
                            @foreach (var ms in Model)
                                {
                                    var status = ms.ComputedStatus;

                                    <tr class="@(
                                        status == MemberShipStatus.Active ? "table-success" :
                                        status == MemberShipStatus.Expired ? "table-warning" :
                                        status == MemberShipStatus.Canceled ? "table-danger" :
                                        ""
                                    )">

                                        <!-- Members -->
                                        <td>@string.Join(", ", ms.Members.Select(m => m.Name))</td>

                                        <!-- Plan -->
                                        <td>@ms.Plan.Name</td>

                                        <!-- Dates -->
                                        <td>@ms.CreatedAt.ToString("MMM dd, yyyy")</td>
                                        <td>@ms.StartDate.ToString("MMM dd, yyyy")</td>
                                        <td>@ms.EndDate.ToString("MMM dd, yyyy")</td>

                                        <!-- Status -->
                                        <td>
                                            @switch (status)
                                            {
                                                case MemberShipStatus.Active:
                                                    <span class="badge bg-success">Active</span>
                                                    break;

                                                case MemberShipStatus.Expired:
                                                    <span class="badge bg-warning text-dark">Expired</span>
                                                    break;

                                                case MemberShipStatus.Canceled:
                                                    <span class="badge bg-danger">Canceled</span>
                                                    break;
                                            }
                                        </td>

                                        <!-- Actions -->
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#cancelModal"
                                                    onclick="setMembershipId(@ms.Id)"
                                                    @(status != MemberShipStatus.Active ? "disabled" : "")>
                                                Cancel
                                            </button>

                                            <button class="btn btn-sm btn-light"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#RenewModal"
                                                    onclick="setRenewMembership(@ms.Id, '@ms.EndDate.ToString("yyyy-MM-dd")')">
                                                Renew
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-person-workspace display-1 text-muted"></i>
                    <h4 class="mt-3 text-muted">No Active Memberships Available</h4>
                </div>
            }
        </div>
    </div>
</div>

<!-- CANCEL MODAL -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Cancel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to cancel this membership?
            </div>

            <div class="modal-footer">
                <form asp-action="CancelMemberShip" method="post">
                    <input type="hidden" id="membershipId" name="id" />
                    <button type="submit" class="btn btn-danger">Yes, Cancel</button>
                </form>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
            </div>

        </div>
    </div>
</div>

<!-- Renew MODAL -->
<div class="modal fade" id="RenewModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Renew</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                
            </div>

            <div class="modal-footer">
                <form asp-action="RenewMemberShip" method="post">
                    <input type="hidden" id="RenewMembershipId" name="id" />
                    <button type="submit" class="btn btn-light">Yes, Renew</button>
                </form>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setMembershipId(id) {
            document.getElementById("membershipId").value = id;
        }
        function setRenewMembershipId(id) {
            document.getElementById("RenewMembershipId").value = id;
        }


        function setRenewMembership(id, endDate) {

            document.getElementById("RenewMembershipId").value = id;

            const end = new Date(endDate);
            const now = new Date();

            const diffTime = end - now;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

            let msg = "";

            if (diffDays > 0)
                msg = `Are you sure you want early renew? Subscription still has ${diffDays} days`;
            else
                msg = "Are you sure you want to renew this expired membership?";

            document.querySelector("#RenewModal .modal-body").innerText = msg;
        }
    </script>
}