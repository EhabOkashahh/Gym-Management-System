@model IEnumerable<MemberShipModelView>

@{
    ViewData["Title"] = "Memberships";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        /* Force dark background for the whole page */
        html, body {
            background-color: var(--black) !important;
            color: var(--white) !important;
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .pf-body {
             background-color: var(--black) !important;
        }

        .memberships-page {
            background-color: var(--black);
            min-height: 100vh;
        }

        /* Modal styling overrides for dark theme */
        .modal-content {
            background-color: var(--dark2) !important;
            color: var(--white) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
        }

        .modal-header, .modal-footer {
            border-color: rgba(255,255,255,0.1) !important;
        }

        .modal-backdrop {
            background-color: #000 !important;
        }

        .modal-backdrop.show {
            opacity: 0.8 !important;
        }

        /* Ensure table doesn't have white background */
        .memberships-table table {
            background-color: var(--dark) !important;
        }
    </style>
}

<div class="memberships-page">

    <!-- HEADER -->
    <header class="sessions-header">
        <div>
            <div class="eyebrow">
                <div class="eyebrow-line"></div>
                <div class="eyebrow-text">Subscription Management</div>
            </div>
            <h2 class="sec-heading">Active <span class="accent">Memberships</span></h2>
            <p class="sessions-sub">Manage and monitor all member subscriptions and their statuses</p>
        </div>
    </header>

    <div class="memberships-table">
        @if (Model != null && Model.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Plan</th>
                        <th>Created</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var ms in Model)
                    {
                        var status = ms.ComputedStatus;

                        string statusClass =
                            status == MemberShipStatus.Active ? "ms-status-active" :
                            status == MemberShipStatus.Expired ? "ms-status-expired" :
                            status == MemberShipStatus.Canceled ? "ms-status-canceled" :
                            "";

                        <tr>
                            <td>
                                <div class="fw-bold">@string.Join(", ", ms.Members.Select(m => m.Name))</div>
                            </td>
                            <td>@ms.Plan.Name</td>
                            <td>@ms.CreatedAt.ToShortDateString()</td>
                            <td>@ms.StartDate.ToShortDateString()</td>
                            <td>@ms.EndDate.ToShortDateString()</td>

                            <!-- STATUS -->
                            <td>
                                <span class="@statusClass fw-bold">
                                    @MemberShip.GetDisplayName(status)
                                </span>
                            </td>

                            <!-- ACTIONS -->
                            <td>
                                <div class="d-flex gap-2">
                                    @{
                                        bool isCanceled = status == MemberShipStatus.Canceled;
                                        bool isExpired = status == MemberShipStatus.Expired;
                                        bool isActive = status == MemberShipStatus.Active;
                                    }

                                    @* Toggle Button (Cancel / Activate) *@
                                    <button class="btn btn-sm @(isCanceled ? "btn-primary-pf" : "btn-outline-pf danger")"
                                            style="padding: 5px 12px; font-size: 11px;"
                                            data-bs-toggle="modal"
                                            data-bs-target="#toggleModal"
                                            onclick="setToggleMembership(@ms.Id, '@status')"
                                            disabled="@(isExpired ? "disabled" : null)">
                                        @(isCanceled ? "Activate" : "Cancel")
                                    </button>

                                    @* Renew Button (Enabled for Active and Expired) *@
                                    <button class="btn-outline-pf"
                                            style="padding: 5px 12px; font-size: 11px;"
                                            data-bs-toggle="modal"
                                            data-bs-target="#renewModal"
                                            onclick="setRenewMembership(@ms.Id, '@ms.EndDate.ToString("yyyy-MM-dd")')"
                                            disabled="@(isCanceled ? "disabled" : null)">
                                        Renew
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">No active memberships found.</div>
        }
    </div>

</div>

<!-- TOGGLE MODAL -->
<div class="modal fade" id="toggleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark2 text-white border-0 shadow-lg">

            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title" id="toggleTitle" style="font-family: var(--font-display); letter-spacing: 1px;">Confirm Action</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4" id="toggleBody"></div>

            <div class="modal-footer border-top border-secondary">
                <form asp-controller="MemberShip"
                      asp-action="ToggleCancelMemberShip"
                      method="post">
                    <input type="hidden" id="toggleMembershipId" name="id" />
                    <button type="submit" id="toggleBtn" class="btn-primary-pf">Confirm</button>
                </form>
                <button type="button" class="btn-outline-pf" data-bs-dismiss="modal">Cancel</button>
            </div>

        </div>
    </div>
</div>

<!-- RENEW MODAL -->
<div class="modal fade" id="renewModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark2 text-white border-0 shadow-lg">

            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title" style="font-family: var(--font-display); letter-spacing: 1px;">Renew Membership</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4" id="renewBody"></div>

            <div class="modal-footer border-top border-secondary">
                <form asp-action="RenewMemberShip" method="post">
                    <input type="hidden" id="renewMembershipId" name="id" />
                    <button type="submit" class="btn-primary-pf">Yes, Renew</button>
                </form>
                <button type="button" class="btn-outline-pf" data-bs-dismiss="modal">No, Back</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    function setToggleMembership(id, status) {
        document.getElementById("toggleMembershipId").value = id;
        const title = document.getElementById("toggleTitle");
        const body = document.getElementById("toggleBody");
        const btn = document.getElementById("toggleBtn");

        if (status === "Canceled") {
            title.innerText = "Activate Membership";
            body.innerText = "Are you sure you want to activate this membership? This will restore member access.";
            btn.innerText = "Yes, Activate";
        } else {
            title.innerText = "Cancel Membership";
            body.innerText = "Are you sure you want to cancel this membership? This will restrict member access until renewed.";
            btn.innerText = "Yes, Cancel";
        }
    }

    function setRenewMembership(id, endDate) {
        document.getElementById("renewMembershipId").value = id;
        const end = new Date(endDate);
        const now = new Date();
        const diffDays = Math.ceil((end - now) / (1000 * 60 * 60 * 24));

        let msg = "";
        if (diffDays > 0)
            msg = `This membership is still active with ${diffDays} days remaining. Do you want to proceed with an early renewal?`;
        else
            msg = "This membership has expired. Proceed with renewal?";

        document.getElementById("renewBody").innerText = msg;
    }
</script>
}
