@model DetailsSessionModelView

@{
    var statusClass = Model.Status == "Ongoing" ? "ongoing" :
                      Model.Status == "Upcoming" ? "upcoming" :
                      Model.Status == "Completed" ? "completed" : "";
}

<div class="session-details-page">

    <!-- HEADER -->
    <div class="session-details-header">
        <h3>Session Details</h3>
        <p>Full information about the training session</p>
    </div>

    <!-- CARD -->
    <div class="session-details-card">

        <!-- TOP SECTION -->
        <div class="session-details-top @statusClass">
            <i class="bi bi-calendar-event"></i>

            <h2 class="session-details-title">
                @Model.CategoryName
            </h2>

            <span class="session-details-badge @statusClass">
                @Model.Status
            </span>
        </div>

        <!-- BODY -->
        <div class="session-details-body">

            <!-- DESCRIPTION -->
            <div class="session-details-block">
                <h6>Description</h6>
                <p>@Model.Description</p>
            </div>

            <!-- GRID -->
            <div class="session-details-grid">

                <div class="session-details-item">
                    <i class="bi bi-person-circle"></i>
                    <div>
                        <small>Trainer</small>
                        <strong>@Model.TrainerName</strong>
                    </div>
                </div>

                <div class="session-details-item">
                    <i class="bi bi-people"></i>
                    <div>
                        <small>Capacity</small>
                        <strong>@Model.ReservedSeats / @Model.Capacity spots</strong>
                    </div>
                </div>

                <div class="session-details-item">
                    <i class="bi bi-calendar-check"></i>
                    <div>
                        <small>Start Time</small>
                        <strong>@Model.StartDate</strong>
                    </div>
                </div>

                <div class="session-details-item">
                    <i class="bi bi-calendar-x"></i>
                    <div>
                        <small>End Time</small>
                        <strong>@Model.EndDate</strong>
                    </div>
                </div>

                @{
                    var time = Model.EndDate - Model.StartDate;
                }

                <div class="session-details-item full">
                    <i class="bi bi-hourglass-split"></i>
                    <div>
                        <small>Duration</small>
                        <strong>@time</strong>
                    </div>
                </div>

            </div>
        </div>

        <!-- FOOTER -->
        <div class="session-details-actions">

            <a asp-action="Index" class="btn-outline-pf">
                Back
            </a>

        </div>

    </div>

</div>