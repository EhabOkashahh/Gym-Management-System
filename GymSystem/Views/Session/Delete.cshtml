@section Styles {
    <link rel="stylesheet" href="~/css/site.css" />
}

<div class="session-delete-page">

    <div class="session-delete-card">

        <!-- ICON -->
        <div class="session-delete-icon">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>

        <!-- TITLE -->
        <h3 class="session-delete-title">
            Delete Session
        </h3>

        <!-- WARNING -->
        <div class="session-delete-warning">
            <i class="bi bi-info-circle"></i>
            <span>
                This action cannot be undone.
                All session data and bookings will be permanently deleted.
            </span>
        </div>

        <!-- CONFIRM TEXT -->
        <p class="session-delete-text">
            Are you sure you want to delete this session?
        </p>

        <!-- SESSION ID -->
        <div class="session-delete-box">
            <small>Session ID</small>
            <strong>#@ViewBag.Id</strong>
        </div>

        <!-- FORM -->
        <form asp-action="Delete" method="post" class="session-delete-actions">

            <input type="hidden" name="id" value="@ViewBag.Id" />

            <a asp-action="Index" class="btn-outline-pf">
                Cancel
            </a>

            <button type="submit" class="btn-primary-pf danger">
                <i class="bi bi-trash"></i>
                Delete
            </button>

        </form>

    </div>

</div>