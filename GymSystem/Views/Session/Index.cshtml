@model IEnumerable<SessionModelView>

@{
    ViewData["Title"] = "Sessions";
}

<div class="sessions-page">

    <!-- HEADER -->
    <div class="sessions-header">
        <div>
            <div class="eyebrow">
                <div class="eyebrow-line"></div>
                <span class="eyebrow-text">Sessions</span>
            </div>

            <h2 class="sec-heading">
                TRAINING <span class="accent">SESSIONS</span>
            </h2>

            <p class="sessions-sub">
                Explore and manage all available training sessions.
            </p>
        </div>

        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
        {
            <a asp-action="Create" class="btn-primary-pf">
                + Add Session
            </a>
        }
    </div>

    <!-- ALERT -->
    @if (TempData["EnrollSuccess"] != null || TempData["EnrollError"] != null)
    {
        <div class="pf-alert @(TempData["EnrollSuccess"] != null ? "success" : "error")" id="pfAlert">
            @TempData["EnrollSuccess"] ?? TempData["EnrollError"]
        </div>
    }

    <!-- CONTENT -->
    @if (Model != null && Model.Any())
    {
        <div class="sessions-grid">
            @foreach (var session in Model)
            {
                <div class="session-card-pf">

                    <!-- STATUS BAR -->
                    <div class="session-status @session.Status.ToLower()">
                        <span>@session.Status</span>
                    </div>

                    <!-- BODY -->
                    <div class="session-body">
                        <h3 class="session-title">@session.CategoryName</h3>

                        <p class="session-desc">
                            @session.Description
                        </p>

                        <div class="session-meta">
                            <div><strong>Trainer:</strong> @session.TrainerName</div>
                            <div><strong>Date:</strong> @session.DateDisplay</div>
                            <div><strong>Time:</strong> @session.TimeRangeDisplay</div>
                            <div><strong>Duration:</strong> @session.Duration</div>
                            <div>
                                <strong>Capacity:</strong>
                                @session.ReservedSeats / @session.Capacity
                            </div>
                        </div>
                    </div>

                    <!-- ACTIONS -->
                    <div class="session-actions">

                        <a asp-action="Details"
                           asp-route-id="@session.Id"
                           class="btn-outline-pf">
                            View
                        </a>

                        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                        {
                            <a asp-action="Edit"
                               asp-route-id="@session.Id"
                               class="btn-outline-pf">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@session.Id"
                               class="btn-outline-pf danger">
                                Delete
                            </a>
                        }
                        else
                        {
                            @if (session.Status == "Completed")
                            {
                                <button class="btn-disabled">Ended</button>
                            }
                            else if (!session.IsEnrolled && session.Capacity - session.ReservedSeats == 0)
                            {
                                <button class="btn-disabled">Full</button>
                            }
                            else if (!session.IsEnrolled)
                            {
                                <form asp-action="Enroll" method="post">
                                    <input type="hidden" name="sessionId" value="@session.Id" />
                                    <button type="submit" class="btn-primary-pf">
                                        Enroll
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Withdraw" method="post">
                                    <input type="hidden" name="sessionId" value="@session.Id" />
                                    <button type="submit" class="btn-outline-pf warning">
                                        Withdraw
                                    </button>
                                </form>
                            }
                        }
                    </div>

                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <h3>No Sessions Available</h3>
            <p>Create your first training session to get started</p>
        </div>
    }

</div>

@section Scripts {
}