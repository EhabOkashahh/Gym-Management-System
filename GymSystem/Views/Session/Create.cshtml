@using GymSystem.DAL.Entites.Enums
@model CreateSessionModelView

<div class="container mt-4">
    <header class="mb-4">
        <h3 class="text-primary-color">Create New Session</h3>
        <p class="text-muted">Schedule a new training session</p>
    </header>

    <form asp-action="Create" method="post">
        <div class="row justify-content-center">
            <div class="col-md-8">

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">

                        <!-- Session Information -->
                        <div class="section-header mb-3">
                            <h5 class="text-primary fw-bold">Session Information</h5>
                            <hr class="mt-2">
                        </div>

                        <div class="row g-3 mb-4">

                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label fw-semibold">
                                    Category <span class="text-danger">*</span>
                                </label>

                                <select asp-for="CategoryId" class="form-select">
                                    <option value="">-- Select Category --</option>

                                    @foreach (var category in Model.Category!)
                                    {
                                        <option value="@category.Id">@category.Name</option>
                                    }

                                </select>

                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                            <!-- Trainer -->
                            <div class="col-md-6">
                                <label asp-for="TrainerId" class="form-label fw-semibold">
                                    Trainer <span class="text-danger">*</span>
                                </label>

                                <select asp-for="TrainerId" class="form-select">
                                    <option value="">-- Select Trainer --</option>

                                    @foreach (var trainer in Model.Trainers!)
                                    {
                                        <option value="@trainer.Id">@trainer.Name</option>
                                    }

                                </select>

                                <span asp-validation-for="TrainerId" class="text-danger"></span>
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold">
                                    Description <span class="text-danger">*</span>
                                </label>

                                <textarea asp-for="Description"
                                          class="form-control"
                                          rows="3"
                                          placeholder="Describe the session content and objectives..."></textarea>

                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <!-- Capacity -->
                            <div class="col-md-6">
                                <label asp-for="Capacity" class="form-label fw-semibold">
                                    Capacity <span class="text-danger">*</span>
                                </label>

                                <input asp-for="Capacity"
                                       type="number"
                                       class="form-control"
                                       min="1"
                                       max="50"
                                       placeholder="25" />

                                <small class="text-muted">
                                    Maximum number of participants
                                </small>

                                <span asp-validation-for="Capacity" class="text-danger d-block"></span>
                            </div>

                        </div>

                        <!-- Date & Time -->
                        <div class="section-header mb-3">
                            <h5 class="text-primary fw-bold">Date & Time</h5>
                            <hr class="mt-2">
                        </div>

                        <div class="row g-3">

                            <!-- Start -->
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label fw-semibold">
                                    Start Date & Time <span class="text-danger">*</span>
                                </label>

                                <input asp-for="StartDate"
                                        id = "StartDateInput"
                                       type="datetime-local"
                                       class="form-control" />

                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>

                            <!-- End -->
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label fw-semibold">
                                    End Date & Time <span class="text-danger">*</span>
                                </label>

                                <input asp-for="EndDate"
                                        id = "EndDateInput"
                                       type="datetime-local"
                                       class="form-control" />

                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>

                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">

                            <a asp-action="Index" class="btn btn-outline">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>

                            <button type="submit" class="btn btn-fill">
                                <i class="bi bi-check-lg me-1"></i>Create Session   
                            </button>

                        </div>

                    </div>
                </div>

            </div>
        </div>
    </form>

    <script>

        function format(today) {
            const year = today.getFullYear();
            const month = String(today.getMonth() + 1).padStart(2, '0');
            const day = String(today.getDate()).padStart(2, '0');

            return `${year}-${month}-${day}`;
        }
        var startDateInput = document.getElementById("StartDateInput")
        var EndDateInput = document.getElementById("EndDateInput")

        startDateInput.value = format(new Date())
        startDateInput.dispatchEvent(new Event("change"))
        EndDateInput.value = format(new Date())
        EndDateInput.dispatchEvent(new Event("change"))
    </script>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}