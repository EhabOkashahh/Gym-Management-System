@using GymSystem.DAL.Entites.Enums
@model CreateSessionModelView

@{
    ViewData["Title"] = "Create Session";
}

@section Styles {
    <link rel="stylesheet" href="~/css/site.css" />
}

<div class="session-create-page">

    <!-- HEADER -->
    <div class="create-header">
        <div class="eyebrow">
            <div class="eyebrow-line"></div>
            <span class="eyebrow-text">Sessions</span>
        </div>

        <h2 class="sec-heading">
            CREATE <span class="accent">SESSION</span>
        </h2>

        <p class="create-sub">
            Schedule and manage your training sessions with precision.
        </p>
    </div>

    <form asp-action="Create" method="post" class="create-form">

        <!-- SESSION INFO -->
        <div class="form-block">
            <h4 class="form-title">Session Information</h4>

            <div class="form-grid">

                <!-- Category -->
                <div class="form-group">
                    <label asp-for="CategoryId">Category</label>
                    <select asp-for="CategoryId">
                        <option value="">Select Category</option>
                        @foreach (var category in Model.Category!)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId"></span>
                </div>

                <!-- Trainer -->
                <div class="form-group">
                    <label asp-for="TrainerId">Trainer</label>
                    <select asp-for="TrainerId">
                        <option value="">Select Trainer</option>
                        @foreach (var trainer in Model.Trainers!)
                        {
                            <option value="@trainer.Id">@trainer.Name</option>
                        }
                    </select>
                    <span asp-validation-for="TrainerId"></span>
                </div>

                <!-- Description -->
                <div class="form-group full">
                    <label asp-for="Description">Description</label>
                    <textarea asp-for="Description" rows="3"></textarea>
                    <span asp-validation-for="Description"></span>
                </div>

                <!-- Capacity -->
                <div class="form-group">
                    <label asp-for="Capacity">Capacity</label>
                    <input asp-for="Capacity" type="number" min="1" max="50" />
                    <span asp-validation-for="Capacity"></span>
                </div>

            </div>
        </div>

        <!-- DATE TIME -->
        <div class="form-block">
            <h4 class="form-title">Date & Time</h4>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="StartDate">Start</label>
                    <input asp-for="StartDate" id="StartDateInput" type="datetime-local" />
                    <span asp-validation-for="StartDate"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EndDate">End</label>
                    <input asp-for="EndDate" id="EndDateInput" type="datetime-local" />
                    <span asp-validation-for="EndDate"></span>
                </div>

            </div>
        </div>

        <!-- ACTIONS -->
        <div class="form-actions">
            <a asp-action="Index" class="btn-outline-pf">Cancel</a>
            <button type="submit" class="btn-primary-pf">Create Session</button>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}