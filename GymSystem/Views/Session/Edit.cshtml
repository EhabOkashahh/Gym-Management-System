@model UpdateSessionModelView

@{
    ViewData["Title"] = "Edit Session";
}
@section Styles {
    <link rel="stylesheet" href="~/css/site.css" />
}
<div class="session-form-page">

    <!-- HEADER -->
    <div class="form-header">
        <div class="eyebrow">
            <div class="eyebrow-line"></div>
            <span class="eyebrow-text">Sessions</span>
        </div>

        <h2 class="sec-heading">
            EDIT <span class="accent">SESSION</span>
        </h2>

        <p class="form-sub">
            Update session details and scheduling.
        </p>
    </div>

    <form asp-action="Edit" method="post" class="pf-form">
        <input type="hidden" asp-for="Id" />

        <!-- BLOCK -->
        <div class="pf-form-block">
            <h4 class="pf-form-title">Session Information</h4>

            <div class="pf-form-grid">

                <div class="pf-form-group">
                    <label asp-for="TrainerId"></label>
                    <select asp-for="TrainerId">
                        <option value="">Select Trainer</option>
                        @foreach (var trainer in Model.Trainers!)
                        {
                            <option value="@trainer.Id">@trainer.Name</option>
                        }
                    </select>
                    <span asp-validation-for="TrainerId"></span>
                </div>

                <div class="pf-form-group">
                    <label asp-for="CategoryId"></label>
                    <select asp-for="CategoryId">
                        <option value="">Select Category</option>
                        @foreach (var category in Model.Category!)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId"></span>
                </div>

                <div class="pf-form-group full">
                    <label asp-for="Description"></label>
                    <textarea asp-for="Description" rows="3"></textarea>
                    <span asp-validation-for="Description"></span>
                </div>

            </div>
        </div>

        <!-- DATE -->
        <div class="pf-form-block">
            <h4 class="pf-form-title">Date & Time</h4>

            <div class="pf-form-grid">

                <div class="pf-form-group">
                    <label asp-for="StartDate"></label>
                    <input asp-for="StartDate" type="datetime-local" />
                    <span asp-validation-for="StartDate"></span>
                </div>

                <div class="pf-form-group">
                    <label asp-for="EndDate"></label>
                    <input asp-for="EndDate" type="datetime-local" />
                    <span asp-validation-for="EndDate"></span>
                </div>

            </div>
        </div>

        <!-- ACTIONS -->
        <div class="pf-form-actions">
            <a asp-action="Index" class="btn-outline-pf">Cancel</a>
            <button type="submit" class="btn-primary-pf">Update Session</button>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}