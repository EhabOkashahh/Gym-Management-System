<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PowerFit</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- ══ NAV ══════════════════════════════════════════════════ -->
    <nav class="pf-nav">

        <a asp-action="Index" asp-controller="Home" class="pf-logo">
            POWER<span>FIT</span>
        </a>

        <ul class="pf-links">
            <li><a asp-action="Index" asp-controller="Home">Home</a></li>

            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
            {
                <li><a asp-controller="Member" asp-action="Index">Members</a></li>
                <li><a asp-controller="Trainer" asp-action="Index">Trainers</a></li>
                <li><a asp-controller="MemberShip" asp-action="Index">Memberships</a></li>
            }

            <li><a asp-controller="Session" asp-action="Index">Sessions</a></li>
            <li><a asp-controller="Plan" asp-action="Index">Plans</a></li>
            <li><a asp-controller="Chat" asp-action="Chat">Support</a></li>

            <li>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:contents">
                    <button type="submit" class="pf-logout-btn">Logout</button>
                </form>
            </li>
        </ul>

        <button class="pf-hamburger" id="pfHamburger" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
    </nav>

    <!-- ══ MOBILE DRAWER ════════════════════════════════════════ -->
    <div class="pf-drawer" id="pfDrawer">
        <ul>
            <li><a asp-action="Index" asp-controller="Home">Home</a></li>

            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
            {
                <li><a asp-controller="Member" asp-action="Index">Members</a></li>
                <li><a asp-controller="Trainer" asp-action="Index">Trainers</a></li>
                <li><a asp-controller="MemberShip" asp-action="Index">Memberships</a></li>
            }

            <li><a asp-controller="Session" asp-action="Index">Sessions</a></li>
            <li><a asp-controller="Plan" asp-action="Index">Plans</a></li>
            <li><a asp-controller="Chat" asp-action="Chat">Support</a></li>

            <li>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:contents">
                    <button type="submit" class="pf-logout-btn">Logout</button>
                </form>
            </li>
        </ul>
    </div>

    <!-- ══ PAGE BODY ═════════════════════════════════════════════ -->
    <div class="pf-body">
        @RenderBody()
    </div>

    <!-- ══ CHAT (non-admin only) ═════════════════════════════════ -->
  

    <!-- ══ SCRIPTS ════════════════════════════════════════════════ -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>