@model PlanModelView
@{
    ViewData["Title"] = "Plan Details";
    var planUsers = Model.MemberShip
                .Where(ms => ms.MemberShipStatus == GymSystemDAL.Entities.Enums.MemberShipStatus.Canceled)
                .SelectMany(ms => ms.Members)
                .Count();
}

<div class="session-details-page">

    <div class="session-details-header">
        <h3>Membership Package</h3>
        <p>Detailed view of the subscription plan</p>
    </div>

    <div class="session-details-card">
        
        <!-- Header -->
        <div class="card-header">
            <i class="bi bi-award display-1 text-red mb-3 d-block"></i>
            <h2 class="session-details-title">@Model.Name</h2>
            <span class="session-details-badge pf-alert @(Model.IsActive ? "success" : "error")">
                @(Model.IsActive ? "Active Plan" : "Inactive Plan")
            </span>
        </div>

        <div class="p-4">
            
            <div class="text-center mb-5 py-4 bg-dark3 rounded">
                <div class="display-1 fw-bold text-red">@Model.Price.ToString("N0")</div>
                <small class="text-gray-light fs-5">EGP</small>
            </div>

            <div class="session-details-grid">
                
                <div class="session-details-item">
                    <i class="bi bi-calendar-check"></i>
                    <div>
                        <small>Duration</small>
                        <strong>@Model.DurationDays Days</strong>
                    </div>
                </div>

                <div class="session-details-item">
                    <i class="bi bi-people"></i>
                    <div>
                        <small>Members Count</small>
                        <div class="d-flex align-items-center gap-3">
                            <strong>@planUsers</strong>
                            @if(planUsers > 0){
                                <button class="btn btn-sm btn-outline-pf py-1 px-2" onclick="loadMembers(@Model.Id)">View List</button>
                            }
                        </div>
                    </div>
                </div>

                <div class="session-details-item full">
                    <i class="bi bi-file-text"></i>
                    <div>
                        <small>Description</small>
                        <strong>@Model.Description</strong>
                    </div>
                </div>

            </div>

            <div class="session-details-actions">
                <a asp-action="Index" class="btn-outline-pf">
                    Back to Plans
                </a>
                @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                {
                    <a asp-action="PlanEdit" asp-route-id="@Model.Id" class="btn-primary-pf">
                        Edit Plan
                    </a>
                }
            </div>

        </div>

    </div>

</div>

<!-- Members Modal -->
<div class="modal fade" id="membersModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-dark2 text-white border-0 shadow-lg" id="membersModalContent">
            <!-- Content will be loaded via AJAX -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadMembers(planId) {
            $.get('/Plan/PlanMembers/' + planId, function (data) {
                $('#membersModalContent').html(data);
                var myModal = new bootstrap.Modal(document.getElementById('membersModal'));
                myModal.show();
            });
        }
    </script>
}
