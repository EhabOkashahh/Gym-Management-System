@model IEnumerable<PlanModelView>
@{
    ViewData["Title"] = "Plans";
}

@section Styles {
    <style>
        /* Minimal grid/flex styles to replace Bootstrap dependencies in this view */
        .plan-grid-pf {
            display: flex;
            flex-wrap: wrap;
            margin: -1rem;
        }
        .plan-col-pf {
            padding: 1rem;
            flex: 0 0 33.333%;
            max-width: 33.333%;
            display: flex;
        }
        @@media (max-width: 992px) {
            .plan-col-pf { flex: 0 0 50%; max-width: 50%; }
        }
        @@media (max-width: 768px) {
            .plan-col-pf { flex: 0 0 100%; max-width: 100%; }
        }

        .plan-card-pf {
            min-height: 450px;
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        /* Force horizontal action row */
        .plan-actions-row {
            display: flex !important;
            flex-direction: row !important;
            gap: 0.5rem !important;
            width: 100%;
            margin-top: auto;
        }
        .plan-actions-row > * {
            flex: 1;
            min-width: 0; /* Allow shrinking */
        }

        /* Override clip-path for small buttons to prevent text cutting */
        .plan-actions-row .btn-outline-pf, 
        .plan-actions-row .btn-primary-pf {
            clip-path: none !important;
            border-radius: 4px !important;
            padding: 0.6rem 0.2rem !important;
            font-size: 0.8rem !important;
            letter-spacing: 0.05em !important;
        }

        /* Ensure theme background */
        .plans-page {
            background: var(--black);
            min-height: 100vh;
        }
    </style>
}

<div class="plans-page">

    <!-- HEADER -->
    <header class="sessions-header">
        <div>
            <div class="eyebrow">
                <div class="eyebrow-line"></div>
                <div class="eyebrow-text">Gym Packages</div>
            </div>
            <h2 class="sec-heading">Membership <span class="accent">Plans</span></h2>
            <p class="sessions-sub">Choose the perfect plan for your fitness journey</p>
        </div>
    </header>

    @if (TempData["ErrorMessage"] is not null)
    {
        <div class="pf-alert error mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    @if (Model is not null && Model.Any())
    {
        <div class="plan-grid-pf mt-2">
            @foreach (var plan in Model)
            {
                <div class="plan-col-pf">
                    <div class="plan-card-pf">
                        
                        <span class="plan-status-badge pf-alert @(plan.IsActive ? "success" : "error")">
                            @(plan.IsActive ? "Active" : "Inactive")
                        </span>

                        <div class="plan-price-tag">
                            @plan.Price <span>EGP</span>
                        </div>

                        <h4 class="plan-name-pf">@plan.Name</h4>

                        <ul class="plan-feature-list">
                            <li class="plan-feature-item">
                                <i class="bi bi-calendar-check"></i>
                                <span>Duration: @plan.DurationDays Days</span>
                            </li>
                            <li class="plan-feature-item">
                                <i class="bi bi-info-circle"></i>
                                <span>@plan.Description</span>
                            </li>
                        </ul>

                        <div class="mt-auto">
                            <div class="plan-actions-row">
                                <a asp-action="PlanDetails" asp-route-id="@plan.Id" class="btn-outline-pf text-center" title="View Details">
                                    Details
                                </a>

                                @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                {
                                    <a asp-action="PlanEdit" asp-route-id="@plan.Id" class="btn-outline-pf text-center" title="Edit Plan">
                                        Edit
                                    </a>

                                    <form asp-action="ToggleStatus" asp-route-id="@plan.Id" method="post">
                                        <button type="submit" class="btn-primary-pf w-100 @(plan.IsActive ? "danger" : "")">
                                            @(plan.IsActive ? "DeActivate" : "Activate")
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">No membership plans available.</div>
    }

</div>
