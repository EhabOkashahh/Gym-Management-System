@model UpdatePlanModelView

@{
    ViewData["Title"] = "Edit Plan";
}

<div class="pf-form-page">

    <div class="pf-form-header">
        <h3>Edit Plan</h3>
        <p class="text-muted">Update plan details and configuration</p>
    </div>

    @Html.ValidationMessage("WrongData", new { @class = "pf-alert error mb-4" })

    <form asp-action="PlanEdit" method="post" class="pf-form-card">
        
        <div asp-validation-summary="ModelOnly" class="pf-alert error mb-4"></div>

        <div class="pf-form-section-title">Plan Details</div>
        
        <div class="pf-form-grid">
            
            <div class="pf-form-group full">
                <label asp-for="Name">Plan Name</label>
                <input asp-for="Name" class="pf-control" placeholder="e.g. Platinum Annual" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="DurationDays">Duration (Days)</label>
                <input asp-for="DurationDays" type="number" class="pf-control" placeholder="30" />
                <span asp-validation-for="DurationDays" class="text-danger"></span>
            </div>

            <div class="pf-form-group">
                <label asp-for="Price">Price (EGP)</label>
                <input asp-for="Price" type="number" step="0.01" class="pf-control" placeholder="1000.00" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="pf-form-group full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="pf-control" rows="5" placeholder="Describe the plan features..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

        </div>

        <div class="pf-form-actions">
            <a asp-action="Index" class="btn-outline-pf">Cancel</a>
            <button type="submit" class="btn-primary-pf">Update Plan</button>
        </div>

    </form>

</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
